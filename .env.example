# NATS
NATS_URL=nats://localhost:4222

# ---------------------------------------------------------------------------
# LLM Configuration — Strict Agent Isolation
# ---------------------------------------------------------------------------
# ARCHITECTURAL RULE: Every agent is an independent participant. Each MUST have
# its own API key and model. No shared fallbacks. This mirrors real-world use:
# any community member can build an agent with their own credentials.
#
# Services (Governor, Banker, World, Town Crier) are market infrastructure —
# they MAY share a key via OPENROUTER_API_KEY.
#
# Free-tier rate limit: 20 req/min, 200 req/day per model.
# Agents are staggered so only 1 decides per tick — stays within limits.

# ---------------------------------------------------------------------------
# Service shared defaults (market infrastructure only)
# ---------------------------------------------------------------------------
OPENROUTER_API_KEY=sk-or-xxxxx
OPENROUTER_API_BASE=https://openrouter.ai/api/v1
DEFAULT_MODEL=google/gemma-3-12b-it:free
DEFAULT_MAX_TOKENS=400
DEFAULT_TEMPERATURE=0.7

# ---------------------------------------------------------------------------
# Per-agent API keys (REQUIRED — economy won't start without them)
# ---------------------------------------------------------------------------
# Each agent MUST have its own {PREFIX}_API_KEY and {PREFIX}_MODEL.
# Optional: {PREFIX}_API_BASE, {PREFIX}_MAX_TOKENS, {PREFIX}_TEMPERATURE.
#
# You can use the SAME API key for all agents (billing convenience) but each
# agent MUST declare its own. Different models per agent = diversity of thought.

FARMER_API_KEY=sk-or-xxxxx
FARMER_MODEL=meta-llama/llama-3.3-70b-instruct:free

CHEF_API_KEY=sk-or-xxxxx
CHEF_MODEL=google/gemma-3-27b-it:free

BAKER_API_KEY=sk-or-xxxxx
BAKER_MODEL=mistralai/mistral-small-3.1-24b-instruct:free

MASON_API_KEY=sk-or-xxxxx
MASON_MODEL=nvidia/nemotron-nano-12b-v2-vl:free

BUILDER_API_KEY=sk-or-xxxxx
BUILDER_MODEL=qwen/qwen3-4b:free

LUMBERJACK_API_KEY=sk-or-xxxxx
LUMBERJACK_MODEL=google/gemma-3-12b-it:free

# ---------------------------------------------------------------------------
# Per-service overrides (optional — falls back to shared defaults above)
# ---------------------------------------------------------------------------
# TOWN_CRIER_API_KEY=sk-or-crier-xxxxx
# TOWN_CRIER_MODEL=
# TOWN_CRIER_MAX_TOKENS=800
# TOWN_CRIER_TEMPERATURE=0.9
#
# WORLD_API_KEY=sk-or-world-xxxxx
# WORLD_MODEL=

# WebSocket Bridge
WS_BRIDGE_HOST=0.0.0.0
WS_BRIDGE_PORT=9090

# ---------------------------------------------------------------------------
# MongoDB (managed agent platform)
# ---------------------------------------------------------------------------
MONGODB_URL=mongodb://localhost:27017
MONGODB_DB=streetmarket

# ---------------------------------------------------------------------------
# Deployment Script (scripts/run_season.py)
# ---------------------------------------------------------------------------
# Required for running a season:
#   OPENROUTER_API_KEY — shared key for all market services
#   DEFAULT_MODEL — LLM model for market services
#
# Run with:
#   make run-season              # Normal speed
#   make run-season-fast         # 2s ticks for testing
#   python scripts/run_season.py --tick-override 2 --no-bridge

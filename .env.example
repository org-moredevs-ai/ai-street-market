# NATS
NATS_URL=nats://localhost:4222

# REQUIRED — OpenRouter is the LLM gateway for all agents and services
OPENROUTER_API_KEY=sk-or-xxxxx
DEFAULT_MODEL=nvidia/nemotron-nano-12b-v2-vl:free

# Optional global defaults
OPENROUTER_API_BASE=https://openrouter.ai/api/v1
DEFAULT_MAX_TOKENS=400
DEFAULT_TEMPERATURE=0.7

# Optional per-agent model overrides (falls back to DEFAULT_MODEL)
# FARMER_MODEL=
# CHEF_MODEL=
# BAKER_MODEL=
# MASON_MODEL=
# BUILDER_MODEL=
# LUMBERJACK_MODEL=
# TOWN_CRIER_MODEL=
# WORLD_MODEL=

# Optional per-agent LLM param overrides
# FARMER_MAX_TOKENS=300
# TOWN_CRIER_MAX_TOKENS=800
# TOWN_CRIER_TEMPERATURE=0.9

# WebSocket Bridge
WS_BRIDGE_HOST=0.0.0.0
WS_BRIDGE_PORT=9090
